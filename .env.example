# HydraWatch environment configuration

# Database
# Leave unset to use local SQLite at data/hydrawatch.db
DATABASE_URL=

# Docker Compose Postgres. Use a real secret locally; never reuse examples in production.
POSTGRES_USER=hydra_user
POSTGRES_PASSWORD=
POSTGRES_DB=hydrawatch_db

# Runtime mode. In production, expensive endpoints require X-API-Key unless explicitly disabled.
ENVIRONMENT=development

# Optional live carbon lookup
ELECTRICITY_MAPS_API_KEY=

# Optional geocoding provider
GOOGLE_MAPS_API_KEY=

# Comma-separated origins, e.g. https://hydrawatch.example.com,http://localhost:5173
CORS_ALLOWED_ORIGINS=https://hydra-watch.onrender.com,http://localhost:5173,http://localhost:8080

# Logging
LOG_LEVEL=INFO

# Public API docs are disabled by default in production. Set true for local/internal debugging.
HYDRAWATCH_ENABLE_API_DOCS=false
HYDRAWATCH_ENABLE_LEGACY_ROUTES=false

# Abuse protection
ANALYZE_RATE_LIMIT_MAX=5
GATE_RATE_LIMIT_MAX=10
GEOCODE_RATE_LIMIT_MAX=20
EXPORT_RATE_LIMIT_MAX=10
ANALYZE_CACHE_TTL_SECONDS=300

# Optional: use Redis instead of per-process in-memory rate limits
REDIS_URL=

# Require X-API-Key for expensive endpoints. Set false only for local development.
HYDRAWATCH_REQUIRE_API_KEY=true
HYDRAWATCH_API_KEYS=

# Optional: permit unauthenticated live Google/Nominatim geocoding. Defaults to false in production.
HYDRAWATCH_ALLOW_PUBLIC_GEOCODING=false

# Optional: Cloudflare Turnstile for public analysis forms
HYDRAWATCH_REQUIRE_TURNSTILE=false
TURNSTILE_SECRET_KEY=
VITE_TURNSTILE_SITE_KEY=
